#!/bin/bash
# ============================================================
# attack_job.sb
# SLURM job template for run_all_attacks.py
#
# Edit MODEL and DATASET before submitting.
# Then: sbatch attack_job.sb
#
# Valid combinations:
#   MODEL=medgemma   DATASET=medqa
#   MODEL=meditron   DATASET=pubmedqa
#   MODEL=meditron   DATASET=medqa
#   MODEL=biomistral DATASET=pubmedqa
#   MODEL=biomistral DATASET=medqa
#   MODEL=openbiollm DATASET=pubmedqa
#   MODEL=openbiollm DATASET=medqa
#
# MedGemma x PubMedQA is already done — skip that combination.
# ============================================================

#SBATCH --job-name=attack_MODEL_DATASET
#SBATCH --account=beqz-delta-gpu
#SBATCH --partition=gpuA40x4
#SBATCH --gpus-per-node=1
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=32g
#SBATCH --time=02:30:00
#SBATCH --output=attack_MODEL_DATASET_%j.out

MODEL=medgemma
DATASET=medqa

echo "=============================="
echo "MODEL:   $MODEL"
echo "DATASET: $DATASET"
echo "=============================="

source /sw/rh9.4/python/miniforge3/etc/profile.d/conda.sh
conda activate medgemma
cd /scratch/beqz/mnataraju/medgemma-project

python run_all_attacks.py --model $MODEL --dataset $DATASET
