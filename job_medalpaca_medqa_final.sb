#!/bin/bash
#SBATCH --job-name=medalpaca_med
#SBATCH --account=beqz-delta-gpu
#SBATCH --partition=gpuA40x4
#SBATCH --gpus-per-node=1
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=32g
#SBATCH --time=12:00:00
#SBATCH --output=medalpaca_medqa_%j.out
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=mnata5@uic.edu
source /sw/rh9.4/python/miniforge3/etc/profile.d/conda.sh
conda activate medgemma
cd /scratch/beqz/mnataraju/medgemma-project
python run_all_attacks.py --model medalpaca --dataset medqa --resume
