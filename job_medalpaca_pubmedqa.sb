#!/bin/bash
#SBATCH --job-name=medalpaca_pubmedqa
#SBATCH --account=beqz-delta-gpu
#SBATCH --partition=gpuA40x4
#SBATCH --gpus-per-node=1
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=32g
#SBATCH --time=02:30:00
#SBATCH --output=medalpaca_pubmedqa_%j.out
source /sw/rh9.4/python/miniforge3/etc/profile.d/conda.sh
conda activate medgemma
cd /scratch/beqz/mnataraju/medgemma-project
python run_all_attacks.py --model medalpaca --dataset pubmedqa
