#!/bin/bash
#SBATCH --job-name=medgemma_medqa
#SBATCH --account=beqz-delta-gpu
#SBATCH --partition=gpuA40x4
#SBATCH --gpus-per-node=1
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=32g
#SBATCH --time=05:00:00
#SBATCH --output=medgemma_medqa_%j.out
source /sw/rh9.4/python/miniforge3/etc/profile.d/conda.sh
conda activate medgemma
cd /scratch/beqz/mnataraju/medgemma-project
python run_all_attacks.py --model medgemma --dataset medqa --resume
